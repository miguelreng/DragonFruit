{
  "name": "lucide-react",
  "version": "0.469.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --no-clean",
    "check:types": "tsc --noEmit",
    "check:format": "oxfmt --check src package.json tsconfig.json tsdown.config.ts",
    "fix:format": "oxfmt src package.json tsconfig.json tsdown.config.ts"
  },
  "dependencies": {
    "@solar-icons/react": "^1.1.1",
    "@plane/icons": "workspace:*",
    "react": "catalog:"
  },
  "devDependencies": {
    "@plane/typescript-config": "workspace:*",
    "@types/react": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
