{
  "name": "@plane/icons",
  "version": "1.3.1",
  "private": true,
  "description": "Shared icon set (HugeIcons) exported under Lucide-compatible names",
  "license": "AGPL-3.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch --no-clean",
    "check:lint": "oxlint .",
    "check:types": "tsc --noEmit",
    "check:format": "oxfmt --check src package.json tsconfig.json tsdown.config.ts",
    "fix:lint": "oxlint --fix .",
    "fix:format": "oxfmt src package.json tsconfig.json tsdown.config.ts",
    "clean": "rm -rf .turbo && rm -rf node_modules && rm -rf dist"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.1.4",
    "@hugeicons/react": "^1.1.6",
    "react": "catalog:"
  },
  "devDependencies": {
    "@plane/typescript-config": "workspace:*",
    "@types/react": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:"
  }
}
