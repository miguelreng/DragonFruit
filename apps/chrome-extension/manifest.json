{
  "manifest_version": 3,
  "name": "DragonFruit",
  "description": "Save pages, images, and tweets to DragonFruit bookmarks, and capture AI chats from Claude, ChatGPT, and Gemini. Open a new tab for a masterpiece from museums worldwide.",
  "version": "0.3.4",
  "icons": {
    "16": "src/icons/icon-16.png",
    "32": "src/icons/icon-32.png",
    "48": "src/icons/icon-48.png",
    "128": "src/icons/icon-128.png"
  },
  "action": {
    "default_icon": {
      "16": "src/icons/action/icon-idle-16.png",
      "32": "src/icons/action/icon-idle-32.png",
      "48": "src/icons/action/icon-idle-48.png",
      "128": "src/icons/action/icon-idle-128.png"
    },
    "default_title": "Save to DragonFruit"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "chrome_url_overrides": {
    "newtab": "src/newtab.html"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["src/content.js"]
    },
    {
      "matches": [
        "https://claude.ai/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*"
      ],
      "js": ["src/capture/extract.js", "src/capture/adapters.js", "src/capture/capture.js"]
    },
    {
      "matches": [
        "https://app.notion.com/*",
        "https://www.notion.so/*",
        "https://*.notion.so/*",
        "https://*.notion.site/*",
        "https://linear.app/*",
        "https://app.asana.com/*",
        "https://*.atlassian.net/*",
        "https://app.clickup.com/*"
      ],
      "js": ["src/capture/extract.js", "src/capture/page-adapters.js", "src/capture/page-capture.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/fonts/Figtree-Variable.ttf"],
      "matches": ["<all_urls>"]
    }
  ],
  "externally_connectable": {
    "matches": ["http://localhost/*", "http://127.0.0.1/*", "https://*.dragonfruit.sh/*"]
  },
  "host_permissions": ["<all_urls>"],
  "permissions": ["activeTab", "contextMenus", "scripting", "storage", "tabs", "windows"]
}
