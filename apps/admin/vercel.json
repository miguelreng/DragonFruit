{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd ../.. && VITE_ADMIN_BASE_PATH=\"${VITE_ADMIN_BASE_PATH:-}\" VITE_API_BASE_URL=\"${VITE_API_BASE_URL:-}\" VITE_WEB_BASE_URL=\"${VITE_WEB_BASE_URL:-}\" VITE_ADMIN_BASE_URL=\"${VITE_ADMIN_BASE_URL:-}\" VITE_SPACE_BASE_URL=\"${VITE_SPACE_BASE_URL:-}\" VITE_LIVE_BASE_URL=\"${VITE_LIVE_BASE_URL:-}\" pnpm turbo run build --filter=admin",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "outputDirectory": "build/client",
  "framework": null,
  "rewrites": [{ "source": "/((?!.*\\.).*)", "destination": "/index.html" }]
}
