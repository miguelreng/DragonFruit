<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Atlas is NOT sandboxed (Accessibility + Core Audio taps + global hotkeys
       are incompatible with the App Sandbox), so it ships via Developer ID.
       Sparkle's embedded framework/XPC services must be loadable under the
       hardened runtime, which requires disabling library validation. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
  <key>com.apple.security.device.audio-input</key>
  <true/>
</dict>
</plist>
