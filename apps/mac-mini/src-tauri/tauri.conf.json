{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DragonFruit Mini",
  "version": "0.1.0",
  "identifier": "io.dragonfruit.mini",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DragonFruit Mini",
        "width": 420,
        "height": 620,
        "minWidth": 360,
        "minHeight": 520,
        "visible": false,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
