{
  "expo": {
    "name": "DragonFruit",
    "slug": "dragonfruit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dragonfruit",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "sh.dragonfruit.mobile",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "sh.dragonfruit.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#AA0276",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-background-task",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/dragon-mark-white.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "backgroundColor": "#AA0276"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3af8e965-d252-48b2-bbde-e654a9ffd013"
      }
    }
  }
}
