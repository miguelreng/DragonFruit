{
  "expo": {
    "name": "DragonFruit",
    "slug": "dragonfruit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "dragonfruit",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "sh.dragonfruit.mobile",
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSMicrophoneUsageDescription": "Allow DragonFruit to listen while you record a command or meeting note.",
        "NSSpeechRecognitionUsageDescription": "Allow DragonFruit to turn your speech into text."
      }
    },
    "android": {
      "package": "sh.dragonfruit.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#AA0276",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-image",
      "expo-background-task",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow DragonFruit to listen while you record a command or meeting note.",
          "speechRecognitionPermission": "Allow DragonFruit to turn your speech into text."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#F4F5F5"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3af8e965-d252-48b2-bbde-e654a9ffd013"
      }
    }
  }
}
