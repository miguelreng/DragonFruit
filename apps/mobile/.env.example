# Web app origin that serves both the auth handoff and the REST API.
# Defaults to https://app.dragonfruit.sh when unset. Point at a local/staging
# backend for development, e.g. http://192.168.1.50:8000 (use your LAN IP, not
# localhost — the device/simulator must be able to reach it).
EXPO_PUBLIC_API_URL=https://app.dragonfruit.sh

# iOS calendar widget. OFF by default: the widget needs an App Group, which
# requires a PAID Apple Developer account, so free / Personal-Team device builds
# stay signable. Set to 1 (and re-run prebuild) once you're on the paid program.
# Note: the widget works on the iOS Simulator for free even with this on.
EXPO_PUBLIC_WIDGET_ENABLED=0
