---
import SiteHeader from "../../components/SiteHeader.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatEssayDate, getEssayDescription, getEssays, getEssaySlug, type Essay } from "../../lib/essays";

export async function getStaticPaths() {
  const essays = await getEssays();

  return essays.map((essay) => ({
    params: { slug: getEssaySlug(essay) },
    props: { essay },
  }));
}

type Props = {
  essay: Essay;
};

const { essay } = Astro.props;
const slug = getEssaySlug(essay);
const title = `${essay.name || "Untitled"} | DragonFruit Essays`;
const description = getEssayDescription(essay);
---

<BaseLayout title={title} description={description} canonicalPath={`/essays/${slug}`} ogType="article">
  <main class="essay-shell">
    <header class="essay-top">
      <SiteHeader />
      <a class="nav-link" href="/essays">all essays</a>
    </header>

    <article class="essay-article">
      <header>
        <p class="meta">DragonFruit essay · {formatEssayDate(essay.created_at)}</p>
        <h1>{essay.name || "Untitled"}</h1>
      </header>

      <div class="essay-body" set:html={essay.description_html || "<p></p>"} />
    </article>
  </main>
</BaseLayout>
