---
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  formatEssayDate,
  getEssayDescription,
  getEssayHeroImage,
  getEssays,
  getEssaysSourceError,
  getEssaySlug,
} from "../../lib/essays";

const essays = await getEssays();
const essaysSourceError = getEssaysSourceError();
---

<BaseLayout
  title="Essays | DragonFruit"
  description="Essays from DragonFruit on productivity, generalists, and agentic workflows."
  canonicalPath="/essays"
>
  <main class="essay-shell essay-index-main">
    <div class="essay-index-copy">
      <header class="essay-top">
        <SiteHeader />
      </header>

      <section class="essay-index-title" aria-labelledby="essays-title">
        <h1 id="essays-title">Essays for the new generalists.</h1>
        <p>Notes, reflections, and field reports on building across disciplines with clarity and momentum.</p>
      </section>

      {
        essays.length > 0 ? (
          <div class="essay-list">
            {essays.map((essay) => {
              const heroImage = getEssayHeroImage(essay);
              const coverAlt = heroImage?.alt || essay.name || "Essay cover image";
              return (
                <a class="essay-list-item" href={`/essays/${getEssaySlug(essay)}`}>
                  {
                    heroImage ? (
                      <div class="essay-list-item-cover-wrap">
                        <img
                          class="essay-list-item-cover"
                          src={heroImage.src}
                          alt={coverAlt}
                          width="120"
                          height="80"
                          loading="lazy"
                        />
                      </div>
                    ) : (
                      <div class="essay-list-item-cover-wrap essay-list-item-cover-placeholder">
                        <span class="essay-list-item-cover-fallback">{essay.name?.slice(0, 1) || "E"}</span>
                      </div>
                    )
                  }
                  <div class="essay-list-item-content">
                    <div class="meta">{formatEssayDate(essay.created_at)}</div>
                    <h2>{essay.name || "Untitled"}</h2>
                    <p>{getEssayDescription(essay)}</p>
                  </div>
                </a>
              );
            })}
          </div>
        ) : (
          <p class="empty-essays">
            {
              essaysSourceError
                ? "Essays are temporarily unavailable from DragonFruit. Please try again in a moment."
                : "No public essays are configured yet."
            }
          </p>
        )
      }
    </div>

    <div class="essay-index-illustration-wrap">
      <img
        class="essay-illustration"
        src="/assets/essays-listing-illustration.png"
        alt="Renaissance-style rose engraving of scholars collaborating with books, notes, and a laptop"
        width="1536"
        height="1024"
      />
    </div>

    <div class="essay-index-footer">
      <SiteFooter />
    </div>
  </main>
</BaseLayout>
