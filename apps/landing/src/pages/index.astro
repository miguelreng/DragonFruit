---
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { pricingPlans } from "../lib/landing";

const proofItems = [
  ["Creators", "Ideas, scripts, research, launches"],
  ["Tech teams", "Specs, triage, docs, decisions"],
  ["Creative studios", "Client work, campaigns, handoffs"],
  ["Self-host builders", "Open source, BYOK, visible control"],
];

const problemCards = [
  {
    number: "01",
    title: "Context lives everywhere but the task.",
    body: "The brief is in a doc, the decision is in chat, the asset is on someone's desktop, and the task only says 'follow up'.",
  },
  {
    number: "02",
    title: "AI starts from a blank prompt.",
    body: "Generic chats can be useful, but they don't know the project, the source material, or what the team already decided.",
  },
  {
    number: "03",
    title: "Project work turns into project archaeology.",
    body: "Before anyone can ship, someone has to reconstruct the plan, rewrite the brief, and guess what still matters.",
  },
];

const featureCards = [
  {
    meta: "Tasks",
    title: "Tasks without the machinery.",
    body: "States, owners, due dates, and per-project custom fields. No sprints, no story points, no setup tax.",
    isNew: false,
  },
  {
    meta: "Docs",
    title: "Docs that stay organized.",
    body: "A calm collaborative editor with folders, templates, and doc-to-doc mentions that keep context linked.",
    isNew: false,
  },
  {
    meta: "Sheets",
    title: "Spreadsheets, next to the work.",
    body: "Real sheets with formulas and tabs, living beside your docs — and Atlas can build or update them from a prompt.",
    isNew: true,
  },
  {
    meta: "Workflows",
    title: "Automations you can draw.",
    body: "Sketch trigger → condition → action flows on a canvas and let Atlas run the routine parts.",
    isNew: true,
  },
  {
    meta: "Capture",
    title: "Capture from anywhere.",
    body: "Clip AI conversations and research into the workspace with the Chrome extension, or drop in raw meeting notes.",
    isNew: false,
  },
  {
    meta: "Integrations",
    title: "Atlas, connected.",
    body: "Plug in your tools with MCP connectors so Atlas can reach the systems your work already lives in.",
    isNew: false,
  },
];

const switchSources = [
  {
    tool: "From Trello",
    mappings: [
      ["Boards", "Projects"],
      ["Cards", "Tasks"],
      ["Labels", "Labels"],
    ],
  },
  {
    tool: "From Asana",
    mappings: [
      ["Projects", "Projects"],
      ["Sections", "States"],
      ["Assignees", "Owners"],
    ],
  },
  {
    tool: "From Notion",
    mappings: [
      ["Databases", "Task lists"],
      ["Pages", "Docs"],
      ["Tags", "Labels"],
    ],
  },
];

const solutionCards = [
  {
    meta: "Capture",
    title: "Drop the messy source material in one room.",
    body: "Notes, transcripts, decisions, docs, tasks, and saved context stay close enough for Atlas to understand the work.",
  },
  {
    meta: "Draft",
    title: "Make the first version instantly useful.",
    body: "Ask Atlas for a project brief, task list, summary, follow-up plan, or launch doc without starting from a blank page.",
  },
  {
    meta: "Triage",
    title: "See what's stuck before the meeting.",
    body: "Atlas can surface missing owners, unresolved questions, stale docs, and risky next steps while the project is still movable.",
  },
  {
    meta: "Approve",
    title: "Keep control before anything changes.",
    body: "Atlas prepares the work, then waits for a human yes before risky edits, assignments, or workflow changes.",
  },
];

const faqs = [
  {
    question: "What is DragonFruit?",
    answer: "An open-source workspace for tasks, docs, and sheets, with one built-in AI teammate, Atlas.",
  },
  {
    question: "What are Sheets?",
    answer: "Lightweight spreadsheets that live alongside your docs — formulas, multiple tabs, no separate app. Atlas can create or update a sheet from a prompt.",
  },
  {
    question: "Is Atlas included in the free Cloud plan?",
    answer: "No. Free is for solo tasks and docs. Atlas is the reason to upgrade to Pro.",
  },
  {
    question: "Can I self-host it?",
    answer: "Yes. DragonFruit is AGPL open source. Run it on your own infrastructure, bring your own model key, and keep full control of your data.",
  },
  {
    question: "How does AI pricing work?",
    answer: "Pro and Business are per-seat. You can bring your own model key, or use Atlas Cloud as a managed usage add-on with spend caps.",
  },
];
---

<BaseLayout
  title="DragonFruit — Tasks, docs, sheets, and one AI teammate"
  description="DragonFruit is an open-source workspace for tasks, docs, and sheets with Atlas, one AI teammate who organizes, drafts, and triages — and asks before anything risky."
  bodyClass="home-page"
>
  <main class="landing-main">
    <section class="landing-hero" aria-labelledby="hero-title">
      <SiteHeader />
      <div class="landing-hero-copy">
        <p class="meta">Atlas™ drafts. You approve.</p>
        <h1 id="hero-title">Where ideas become work.</h1>
        <p>
          DragonFruit™ is the calm workspace — tasks, docs, and sheets — where Atlas, your AI teammate, turns raw
          notes into drafts, plans, and shipped tasks.
        </p>
        <div class="landing-actions">
          <a class="primary-action" href="https://app.dragonfruit.sh">Start free</a>
          <a class="secondary-action" href="/pricing">See pricing</a>
        </div>
        <div class="landing-proof" aria-label="DragonFruit principles">
          <span>Tasks</span>
          <span>Docs</span>
          <span>Sheets</span>
          <span>Atlas</span>
          <span>BYOK</span>
          <span>AGPL</span>
        </div>
      </div>

      <div class="landing-hero-media">
        <div class="product-window" role="img" aria-label="DragonFruit workspace preview">
          <div class="product-rail" aria-hidden="true">
            <span class="product-rail-mark is-active"></span>
            <span class="product-rail-mark"></span>
            <span class="product-rail-mark"></span>
            <span class="product-rail-mark"></span>
          </div>
          <div class="product-sidebar" aria-hidden="true">
            <span class="product-sidebar-title">DragonFruit</span>
            <span class="product-sidebar-item is-active">Launch room</span>
            <span class="product-sidebar-item">Docs</span>
            <span class="product-sidebar-item">Sheets</span>
            <span class="product-sidebar-item">Tasks</span>
            <span class="product-sidebar-item">Atlas</span>
          </div>
          <div class="product-canvas">
            <div class="product-toolbar">
              <div>
                <span class="product-kicker">Project</span>
                <strong>Founder launch plan</strong>
              </div>
              <span class="status-chip">Atlas ready</span>
            </div>

            <div class="product-doc-card">
              <div class="product-doc-top">
                <span class="product-icon" aria-hidden="true">D</span>
                <div>
                  <span class="product-kicker">Meeting note</span>
                  <h3>Launch plan brain dump</h3>
                </div>
              </div>
              <p>Messy notes, open questions, owner decisions, and half-written positioning in one doc.</p>
              <div class="product-tags" aria-label="Document tags">
                <span>Spec</span>
                <span>Transcript</span>
                <span>Risks</span>
              </div>
            </div>

            <div class="product-task-list" aria-label="Generated tasks">
              <div class="product-task-row">
                <span class="task-check" aria-hidden="true"></span>
                <span>Draft launch doc from notes</span>
                <span class="task-pill">Today</span>
              </div>
              <div class="product-task-row">
                <span class="task-check" aria-hidden="true"></span>
                <span>Assign customer follow-ups</span>
                <span class="task-pill">3 owners</span>
              </div>
              <div class="product-task-row">
                <span class="task-check" aria-hidden="true"></span>
                <span>Approve public changelog</span>
                <span class="task-pill is-warning">Review</span>
              </div>
            </div>

            <div class="product-atlas-card">
              <span class="atlas-avatar" aria-hidden="true">A</span>
              <p><strong>Atlas suggests</strong> 6 tasks, 3 risks, and one launch doc. Approval required before changes.</p>
            </div>

            <div class="product-media-card">
              <video
                class="landing-hero-video"
                data-home-video
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
                aria-label="Renaissance-style scene of a small coworking meeting with people using laptops and a phone"
                width="1536"
                height="1024"
              >
                <source media="(max-width: 860px)" src="/assets/hero-video-loop-mobile.mp4" type="video/mp4" />
                <source media="(min-width: 861px)" src="/assets/hero-video-loop.mp4" type="video/mp4" />
                <source src="/assets/hero-video-smooth.mp4" type="video/mp4" />
              </video>
              <span>Context asset</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="reference-proof" aria-labelledby="proof-title">
      <div class="reference-proof-heading">
        <p class="meta">Built for the work between thinking and shipping</p>
        <h2 id="proof-title">One workspace for creators, tech teams, creative studios, and self-host builders.</h2>
      </div>
      <div class="proof-strip" aria-label="DragonFruit audiences">
        {proofItems.map(([label, body]) => (
          <article>
            <strong>{label}</strong>
            <span>{body}</span>
          </article>
        ))}
      </div>
    </section>

    <section class="landing-section problem-section" aria-labelledby="problem-title">
      <div class="landing-section-heading is-centered">
        <p class="meta">The problem</p>
        <h2 id="problem-title">The gap between idea and work is where momentum dies.</h2>
        <p>
          Most tools separate the thing you know from the thing you need to do next. That leaves everyone rebuilding
          context instead of moving the work forward.
        </p>
      </div>

      <div class="problem-grid">
        {problemCards.map((problem) => (
          <article class="problem-card">
            <span>{problem.number}</span>
            <h3>{problem.title}</h3>
            <p>{problem.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="landing-section solution-section" id="product" aria-labelledby="solution-title">
      <div class="landing-section-heading is-centered">
        <p class="meta">Atlas</p>
        <h2 id="solution-title">Hand off the busywork. Keep the credit.</h2>
        <p>
          Give Atlas the raw idea. He reads the project around it and drafts the useful first version: the brief, the
          plan, the task list, or the decision summary.
        </p>
      </div>

      <div class="solution-grid">
        {solutionCards.map((feature) => (
          <article class="solution-card">
            <span>{feature.meta}</span>
            <h3>{feature.title}</h3>
            <p>{feature.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="landing-section feature-section" id="features" aria-labelledby="features-title">
      <div class="landing-section-heading is-centered">
        <p class="meta">What's inside</p>
        <h2 id="features-title">A full workspace, kept deliberately small.</h2>
        <p>
          Six sharp tools instead of forty modules. Everything lives in one place, so everything is context Atlas can
          work with.
        </p>
      </div>

      <div class="feature-grid">
        {featureCards.map((feature) => (
          <article class="feature-card">
            {feature.isNew && <span class="feature-new">New</span>}
            <span class="feature-meta">{feature.meta}</span>
            <h3>{feature.title}</h3>
            <p>{feature.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="landing-section switch-section" id="switch" aria-labelledby="switch-title">
      <div class="landing-section-heading is-centered">
        <p class="meta">Switching</p>
        <h2 id="switch-title">Bring your current setup with you.</h2>
        <p>
          Export from the tool you're leaving and land it here in an afternoon. Boards, projects, and pages arrive as
          native tasks and docs — nothing to rebuild by hand.
        </p>
      </div>

      <div class="switch-strip" aria-label="Supported migrations">
        {switchSources.map((source) => (
          <article>
            <strong>{source.tool}</strong>
            <ul>
              {source.mappings.map(([from, to]) => (
                <li>
                  {from}
                  <span>→ {to}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>

      <p class="switch-note">
        One-time import instead of a fragile two-way sync — your old tool stays untouched while you settle in. Once
        everything lands, Atlas triages the pile: owners, states, duplicates, and the real next steps.
      </p>
    </section>

    <section class="landing-section" aria-labelledby="pricing-title">
      <div class="landing-section-heading">
        <p class="meta">Pricing</p>
        <h2 id="pricing-title">Free for tasks and docs. Paid when Atlas joins the work.</h2>
        <p>
          Start solo for free. Upgrade to Pro when Atlas becomes part of your daily flow. Bring your own key, or use
          Atlas Cloud when you want managed usage.
        </p>
      </div>

      <div class="pricing-grid">
        {pricingPlans.map((plan) => (
          <article class="pricing-card" data-spotlight-card>
            <span>{plan.name}</span>
            <h2>{plan.price}</h2>
            <p class="price-detail">{plan.priceDetail}</p>
            <p>{plan.body}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="landing-open-source" aria-labelledby="open-source-title">
      <div>
        <p class="meta">Open source</p>
        <h2 id="open-source-title">Open source is the trust model, not a side project.</h2>
      </div>
      <p>
        DragonFruit is AGPL. Inspect the code, self-host when control matters, or use Cloud when you want the product
        without running infrastructure. Built on Plane, with Atlas as the opinionated teammate layer.
      </p>
    </section>

    <section class="landing-section landing-faq" aria-labelledby="faq-title">
      <div class="landing-section-heading">
        <p class="meta">FAQ</p>
        <h2 id="faq-title">The important details.</h2>
      </div>

      <div class="faq-list">
        {faqs.map((faq) => (
          <details>
            <summary>{faq.question}</summary>
            <p>{faq.answer}</p>
          </details>
        ))}
      </div>
    </section>

    <section class="landing-final" aria-labelledby="final-title">
      <div>
        <p class="meta">Start</p>
        <h2 id="final-title">Bring one messy project. Let Atlas organize the next move.</h2>
        <p>Open-source. Self-hostable. Bring your own AI key.</p>
      </div>
      <a class="primary-action" href="https://app.dragonfruit.sh">Start free</a>
    </section>

    <SiteFooter />
  </main>

  <script is:inline>
    (() => {
      const video = document.querySelector('[data-home-video]');
      if (!video) return;

      const showVideo = () => video.classList.add('is-visible');
      if (video.readyState >= 2) {
        requestAnimationFrame(showVideo);
        return;
      }

      video.addEventListener('loadeddata', showVideo, { once: true });
      window.setTimeout(showVideo, 900);

    })();
  </script>
</BaseLayout>
