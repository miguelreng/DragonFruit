---
type Props = {
  showEssaysLink?: boolean;
};

const { showEssaysLink = false } = Astro.props;
---

<div class="topbar">
  <a class="brand-link" href="/" aria-label="DragonFruit home">
    <img class="brand" src="/assets/logo.svg" alt="DragonFruit" width="184" height="41" />
  </a>
  <nav class="top-nav" aria-label="Primary">
    <a class="nav-link" href="/#product">Product</a>
    <a class="nav-link" href="/atlas">Atlas</a>
    <a class="nav-link" href="/pricing">Pricing</a>
    <a class="nav-link" href="/open-source">Open source</a>
    {showEssaysLink && <a class="nav-link" href="/essays">Essays</a>}
    <a class="nav-link nav-cta" href="https://app.dragonfruit.sh">Start free</a>
  </nav>
</div>
