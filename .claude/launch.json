{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "web (main React Router app)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter=web", "dev"],
      "port": 3000
    },
    {
      "name": "web-local-api (folders verify)",
      "runtimeExecutable": "bash",
      "runtimeArgs": [
        "-c",
        "cd apps/web && VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:8000 pnpm exec react-router dev --port 3005"
      ],
      "port": 3005
    },
    {
      "name": "web-local-api-alt (charts verify)",
      "runtimeExecutable": "bash",
      "runtimeArgs": [
        "-c",
        "cd apps/web && VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:8000 pnpm exec react-router dev --port 3006"
      ],
      "port": 3006
    },
    {
      "name": "web-local-api-3008 (atlas full mode verify)",
      "runtimeExecutable": "bash",
      "runtimeArgs": [
        "-c",
        "cd apps/web && VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:8000 pnpm exec react-router dev --port 3008"
      ],
      "port": 3008
    },
    {
      "name": "web-local-api-3007 (link preview verify)",
      "runtimeExecutable": "bash",
      "runtimeArgs": [
        "-c",
        "cd apps/web && VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:8001 pnpm exec react-router dev --port 3007"
      ],
      "port": 3007
    },
    {
      "name": "landing (Astro marketing site)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter=landing", "dev"],
      "port": 3003
    },
    {
      "name": "admin (instance admin UI)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter=admin", "dev"],
      "port": 3001
    },
    {
      "name": "space (public publishing app)",
      "runtimeExecutable": "pnpm",
      "runtimeArgs": ["--filter=space", "dev"],
      "port": 3002
    },
    {
      "name": "live (HocusPocus realtime collab — needs Redis)",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd apps/live && PORT=3100 pnpm dev"],
      "port": 3100
    },
    {
      "name": "api (Django backend — needs Postgres + Redis)",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd apps/api && python manage.py runserver 0.0.0.0:8000 --settings=plane.settings.local"],
      "port": 8000
    },
    {
      "name": "newtab-art-preview (temp static harness)",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd /tmp/ntpreview && python3 -m http.server 8743"],
      "port": 8743
    },
    {
      "name": "propel-storybook (component gallery)",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd packages/propel && COREPACK_INTEGRITY_KEYS=0 pnpm storybook --no-open"],
      "port": 6006
    }
  ]
}
